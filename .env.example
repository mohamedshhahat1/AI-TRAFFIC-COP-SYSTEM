# ============================================
# AI Traffic Cop System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# -------- Server --------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# -------- Database --------
# SQLite (default - good for development)
DATABASE_URL=sqlite+aiosqlite:///./data/traffic_cop.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/traffic_cop

# -------- CORS --------
# Comma-separated list of allowed origins
# Leave empty to use defaults (localhost:3000, localhost:8000)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -------- Authentication --------
# API Key for protecting sensitive endpoints (camera control, delete, upload)
# Leave empty to disable auth (development only!)
API_KEY=
# JWT Secret (for future token-based auth)
JWT_SECRET=change-me-in-production

# -------- Rate Limiting --------
RATE_LIMIT_PER_MINUTE=60

# -------- Email Alerts --------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
ALERT_EMAIL=

# -------- Frontend --------
# Used by React app
REACT_APP_API_URL=/api
# REACT_APP_WS_URL=ws://your-domain.com/ws/live
