<?xml version="1.0" encoding="UTF-8"?>
<!-- Single 4-way intersection for RL training -->
<net version="1.20" junctionCornerDetail="5" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/net_file.xsd">

    <location netOffset="500.00,500.00" convBoundary="0.00,0.00,1000.00,1000.00"
              origBoundary="-500.00,-500.00,500.00,500.00" projParameter="!"/>

    <!-- Edges (roads approaching intersection) -->
    <!-- North approach -->
    <edge id="N_in" from="N" to="TL0" priority="2" numLanes="2" speed="13.89">
        <lane id="N_in_0" index="0" speed="13.89" length="500.00" shape="498.40,1000.00 498.40,510.00"/>
        <lane id="N_in_1" index="1" speed="13.89" length="500.00" shape="501.60,1000.00 501.60,510.00"/>
    </edge>
    <edge id="N_out" from="TL0" to="N" priority="2" numLanes="2" speed="13.89">
        <lane id="N_out_0" index="0" speed="13.89" length="500.00" shape="498.40,510.00 498.40,1000.00"/>
        <lane id="N_out_1" index="1" speed="13.89" length="500.00" shape="501.60,510.00 501.60,1000.00"/>
    </edge>

    <!-- South approach -->
    <edge id="S_in" from="S" to="TL0" priority="2" numLanes="2" speed="13.89">
        <lane id="S_in_0" index="0" speed="13.89" length="500.00" shape="501.60,0.00 501.60,490.00"/>
        <lane id="S_in_1" index="1" speed="13.89" length="500.00" shape="498.40,0.00 498.40,490.00"/>
    </edge>
    <edge id="S_out" from="TL0" to="S" priority="2" numLanes="2" speed="13.89">
        <lane id="S_out_0" index="0" speed="13.89" length="500.00" shape="501.60,490.00 501.60,0.00"/>
        <lane id="S_out_1" index="1" speed="13.89" length="500.00" shape="498.40,490.00 498.40,0.00"/>
    </edge>

    <!-- East approach -->
    <edge id="E_in" from="E" to="TL0" priority="2" numLanes="2" speed="13.89">
        <lane id="E_in_0" index="0" speed="13.89" length="500.00" shape="1000.00,501.60 510.00,501.60"/>
        <lane id="E_in_1" index="1" speed="13.89" length="500.00" shape="1000.00,498.40 510.00,498.40"/>
    </edge>
    <edge id="E_out" from="TL0" to="E" priority="2" numLanes="2" speed="13.89">
        <lane id="E_out_0" index="0" speed="13.89" length="500.00" shape="510.00,501.60 1000.00,501.60"/>
        <lane id="E_out_1" index="1" speed="13.89" length="500.00" shape="510.00,498.40 1000.00,498.40"/>
    </edge>

    <!-- West approach -->
    <edge id="W_in" from="W" to="TL0" priority="2" numLanes="2" speed="13.89">
        <lane id="W_in_0" index="0" speed="13.89" length="500.00" shape="0.00,498.40 490.00,498.40"/>
        <lane id="W_in_1" index="1" speed="13.89" length="500.00" shape="0.00,501.60 490.00,501.60"/>
    </edge>
    <edge id="W_out" from="TL0" to="W" priority="2" numLanes="2" speed="13.89">
        <lane id="W_out_0" index="0" speed="13.89" length="500.00" shape="490.00,498.40 0.00,498.40"/>
        <lane id="W_out_1" index="1" speed="13.89" length="500.00" shape="490.00,501.60 0.00,501.60"/>
    </edge>

    <!-- Junctions -->
    <junction id="TL0" type="traffic_light" x="500.00" y="500.00"
              incLanes="N_in_0 N_in_1 S_in_0 S_in_1 E_in_0 E_in_1 W_in_0 W_in_1"
              intLanes="" shape="496.80,510.00 503.20,510.00 510.00,503.20 510.00,496.80 503.20,490.00 496.80,490.00 490.00,496.80 490.00,503.20"/>
    <junction id="N" type="dead_end" x="500.00" y="1000.00"/>
    <junction id="S" type="dead_end" x="500.00" y="0.00"/>
    <junction id="E" type="dead_end" x="1000.00" y="500.00"/>
    <junction id="W" type="dead_end" x="0.00" y="500.00"/>

    <!-- Traffic Light Program -->
    <tlLogic id="TL0" type="static" programID="0" offset="0">
        <!-- Phase 0: North-South Green -->
        <phase duration="30" state="GGrrGGrr"/>
        <!-- Phase 1: North-South Yellow -->
        <phase duration="3" state="yyrryyrr"/>
        <!-- Phase 2: East-West Green -->
        <phase duration="30" state="rrGGrrGG"/>
        <!-- Phase 3: East-West Yellow -->
        <phase duration="3" state="rryyrryy"/>
    </tlLogic>

</net>
